# ── App server ────────────────────────────────────────────────────────────────
# Port the Express server listens on. Cloud Run injects PORT automatically.
PORT=3000
NODE_ENV=development

# ── Firebase (server / Admin SDK) ───────────────────────────────────────────────
# In production on Cloud Run, the Admin SDK uses Application Default Credentials
# from the service account — no key file needed (ADR-0001). projectId can be set
# explicitly here or via GOOGLE_CLOUD_PROJECT.
GOOGLE_CLOUD_PROJECT=personal-library-manager-frank

# ── Firebase (client / public web config) ───────────────────────────────────────
# These are PUBLIC identifiers (safe in the browser bundle), not secrets.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=personal-library-manager-frank.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=personal-library-manager-frank
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=personal-library-manager-frank.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── AI vision layer (server-only secrets, #19) ──────────────────────────────────
# API keys for the AI engines that identify books from photos. These are SERVER
# secrets — never exposed to the browser and never written by the app. In
# production they come from Secret Manager; locally set them here. An engine with
# no key reports "not configured" and the orchestrator falls back to the other.
# Engine selection (default engine + fallback toggle) is NOT here — it lives in the
# Firestore `settings/ai` document, editable from the settings screen (#19b).
OPENAI_API_KEY=
GEMINI_API_KEY=
# Optional vision model overrides (sensible defaults applied when unset).
# OPENAI_VISION_MODEL=gpt-4o
# GEMINI_VISION_MODEL=gemini-2.0-flash

# ── Local development with the Firebase Emulator Suite ──────────────────────────
# Set these (in .env.local) to route both SDKs to the local emulators. Leave unset
# in production so the app targets the real project.
NEXT_PUBLIC_FIREBASE_USE_EMULATOR=true
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
