{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "incremental": false,
    "isolatedModules": false
  },
  "include": ["server/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist", "app", "components"]
}
